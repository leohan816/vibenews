# VibeNews server config — NAMES/placeholders only. Real values live solely in the ignored
# mode-600 .env.server.local (never committed) or device SecureStore. Do not put secrets here.

# Implementation-defined server runtime (required before start; not claimed currently prepared)
VIBENEWS_ENV=
VIBENEWS_BIND_HOST=127.0.0.1
VIBENEWS_PORT=
VIBENEWS_STATE_DIR=
VIBENEWS_USER_TIMEZONE=Asia/Seoul
VIBENEWS_DEVICE_TOKEN_SHA256=
YTDLP_BINARY=

# Advisor-confirmed prepared D-003 provider key names (names only; values undisclosed, set out-of-band)
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=
DEEPSEEK_BUILDER_MODEL=
DEEPSEEK_VERIFIER_MODEL=
DEEPSEEK_VERIFIER_REASONING_EFFORT=
FISH_API_KEY=
FISH_TTS_MODEL=
FISH_REFERENCE_ID=

# Client nonsecret (Expo inlines EXPO_PUBLIC_*). This is the tailnet-only Tailscale Serve HTTPS URL.
EXPO_PUBLIC_VIBENEWS_API_BASE_URL=
