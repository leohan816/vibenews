  "scripts": {
    "start": "expo start",
    "reset-project": "node ./scripts/reset-project.js",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "lint": "eslint --config node_modules/eslint-config-expo/flat.js src/api src/audio src/storage src/components/add src/components/progress-bar.tsx src/components/chapter-controls.tsx src/data/types.ts src/lib/audio.ts src/lib/eventLog.ts src/app/_layout.tsx 'src/app/(tabs)/_layout.tsx' 'src/app/(tabs)/index.tsx' 'src/app/(tabs)/add.tsx' 'src/app/(tabs)/settings.tsx' src/app/briefing.tsx src/app/briefing-session.tsx server",
