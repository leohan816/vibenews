    "test:unit": "node --import tsx --test 'server/test/unit/*.test.ts'",
    "test:integration": "node --import tsx --test 'server/test/integration/*.test.ts'",
    "test:runtime-local": "node --import tsx --test 'server/test/runtime/*.test.ts'",
    "server:migrate": "tsx server/src/bin/migrate.ts",
    "server:config-check": "tsx server/src/config.ts",
    "server:api": "tsx server/src/bin/api.ts",
    "server:worker": "tsx server/src/bin/worker.ts",
    "server:poller": "tsx server/src/bin/poller.ts",
    "server:backup": "tsx server/src/bin/backup.ts",
    "accept:private": "tsx server/src/bin/accept-private.ts"
